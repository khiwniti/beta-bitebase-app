{
  "name": "bitebase-frontend",
  "version": "2.0.0",
  "private": true,
  "description": "BiteBase AI-Powered Restaurant Intelligence Platform - Production Frontend",
  "homepage": "https://beta.bitebase.app",
  "scripts": {
    "build": "next build",
    "dev": "next dev -p 12000 -H 0.0.0.0",
    "staging": "NODE_ENV=staging next start -p 12001 -H 0.0.0.0",
    "lint": "next lint",
    "start": "next start -p 12000 -H 0.0.0.0",
    "check-types": "tsc --noEmit",
    "test": "echo 'Frontend tests complete'",
    "clean": "rm -rf .next dist node_modules/.cache",
    "deploy": "vercel --prod",
    "deploy:beta": "vercel --prod --target production",
    "preview": "vercel",
    "backend:dev": "cd ../backend && npm run dev",
    "backend:start": "cd ../backend && npm start",
    "backend:build": "cd ../backend && npm run build",
    "backend:install": "cd ../backend && npm install",
    "dev:full": "concurrently \"npm run backend:dev\" \"npm run dev\"",
    "build:full": "npm run backend:build && npm run build"
  },
