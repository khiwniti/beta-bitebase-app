# BiteBase Frontend Environment Configuration

# Application URLs
NEXT_PUBLIC_APP_URL=https://beta.bitebase.app
NEXT_PUBLIC_API_URL=https://api.bitebase.app
NEXT_PUBLIC_BACKEND_URL=https://api.bitebase.app

# Map Services
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_access_token_here

# Feature Flags
NEXT_PUBLIC_ENABLE_MAPS=true
NEXT_PUBLIC_ENABLE_AI_CHAT=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Analytics and Monitoring
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn-here

# Stripe (for payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here

# Social Media Integration
NEXT_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id
NEXT_PUBLIC_TWITTER_API_KEY=your_twitter_api_key

# Development Settings
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_LOG_LEVEL=info

# Beta Testing
NEXT_PUBLIC_BETA_FEATURES=true
NEXT_PUBLIC_FEEDBACK_ENABLED=true