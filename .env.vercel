# NEXT_PUBLIC_TWITTER_API_KEY=your_twitter_api_key

# ===== FOURSQUARE API CONFIGURATION =====
NEXT_PUBLIC_FOURSQUARE_API_KEY=fsq3Ciis2M5OLrAUQqL2V5z+bsUMKpCCdQe1ULDMN23ISSo=

# ===== CORS CONFIGURATION =====
NEXT_PUBLIC_CORS_ORIGIN=https://beta.bitebase.app

# ===== CACHE CONFIGURATION =====
NEXT_PUBLIC_CACHE_ENABLED=true
NEXT_PUBLIC_CACHE_TTL=300

# ===== PERFORMANCE SETTINGS =====
NEXT_PUBLIC_REQUEST_TIMEOUT=30000
NEXT_PUBLIC_MAX_RETRIES=3
NEXT_PUBLIC_RETRY_DELAY=1000
